# Copy to .env and fill in your Auth0 values.
#
# Auth0 settings for API JWT validation:
# - AUTH0_ISSUER_BASE_URL: e.g. https://YOUR_TENANT.us.auth0.com/
# - AUTH0_AUDIENCE: your API Identifier in Auth0 (Dashboard -> APIs -> Identifier)

AUTH0_ISSUER_BASE_URL=https://YOUR_TENANT.us.auth0.com/
AUTH0_AUDIENCE=YOUR_API_IDENTIFIER

# In docker-compose we override MONGODB_URI to point at mongo container.
MONGODB_URI=mongodb://localhost:27017/hackaz

# CORS allowlist (comma-separated). For local dev: http://localhost:3000
CLIENT_ORIGIN=http://localhost:3000

PORT=5000

