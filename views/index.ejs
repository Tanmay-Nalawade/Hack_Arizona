<% layout("layout") %>

<section class="home">
  <header class="home__header">
    <div>
      <h1 class="home__title">Your quests</h1>
      <p class="home__subtitle">Follow the path. Finish today’s lesson to keep your streak alive.</p>
    </div>

    <div class="pillRow" aria-label="Quick stats">
      <div class="pill">
        <span class="pill__label">Streak</span>
        <span class="pill__value"><span id="homeStreak">0</span> days</span>
      </div>
      <div class="pill">
        <span class="pill__label">XP</span>
        <span class="pill__value">120</span>
      </div>
    </div>
  </header>

  <div class="home__grid home__grid--duo">
    <section class="mapCard" aria-label="Quest map">
      <div class="mapCard__header">
        <div class="mapCard__unit">
          <span class="mapCard__unitPill">Unit 1</span>
          <span class="mapCard__unitTitle">Food Bank Foundations</span>
        </div>
        <a class="btn btn--ghost" href="/coursework">View coursework</a>
      </div>

      <div class="duoMap duoMap--h" role="group" aria-label="Quest path">
        <div class="duoMap__bg" aria-hidden="true"></div>

        <svg class="duoMap__path duoMap__path--h" viewBox="0 0 1400 280" aria-hidden="true">
          <path
            d="M70 140
               C 200 30, 340 30, 470 140
               C 600 250, 740 250, 870 140
               C 1000 30, 1140 30, 1270 140
               C 1350 210, 1390 210, 1370 140"
            fill="none"
            stroke="rgba(214, 162, 31, 0.65)"
            stroke-width="18"
            stroke-linecap="round"
          />
          <path
            d="M70 140
               C 200 30, 340 30, 470 140
               C 600 250, 740 250, 870 140
               C 1000 30, 1140 30, 1270 140
               C 1350 210, 1390 210, 1370 140"
            fill="none"
            stroke="rgba(255, 255, 255, 0.72)"
            stroke-width="8"
            stroke-linecap="round"
          />
        </svg>

        <ol class="duoNodes duoNodes--h" aria-label="Lessons">
          <li class="duoNode duoNode--done" style="--x: 90px; --y: 140px" data-title="Basics 1" data-desc="Greetings, common phrases, quick wins.">
            <button class="duoNode__btn" type="button" aria-label="Basics 1">
              <span class="duoNode__icon" aria-hidden="true">✅</span>
            </button>
          </li>

          <li class="duoNode duoNode--done" style="--x: 250px; --y: 85px" data-title="Basics 2" data-desc="Listening + matching exercises.">
            <button class="duoNode__btn" type="button" aria-label="Basics 2">
              <span class="duoNode__icon" aria-hidden="true">✅</span>
            </button>
          </li>

          <li class="duoNode duoNode--current" style="--x: 460px; --y: 140px" data-title="Food Bank Tour" data-desc="Key terms you’ll see across the Food Bank experience.">
            <button class="duoNode__btn" type="button" aria-label="Food Bank Tour">
              <span class="duoNode__icon" aria-hidden="true">⭐</span>
              <span class="duoNode__pulse" aria-hidden="true"></span>
            </button>
          </li>

          <li class="duoNode duoNode--locked" style="--x: 600px; --y: 205px" data-title="Check-in Desk" data-desc="Learn what to bring and what to expect at check-in.">
            <button class="duoNode__btn" type="button" aria-label="Check-in Desk" disabled>
              <span class="duoNode__icon" aria-hidden="true">🔒</span>
            </button>
          </li>

          <li class="duoNode duoNode--locked" style="--x: 760px; --y: 205px" data-title="Community Helpers" data-desc="Unlock after finishing today’s quest.">
            <button class="duoNode__btn" type="button" aria-label="Community Helpers" disabled>
              <span class="duoNode__icon" aria-hidden="true">🔒</span>
            </button>
          </li>

          <li class="duoNode duoNode--locked" style="--x: 900px; --y: 140px" data-title="Food Categories" data-desc="Practice names for staples, produce, and pantry items.">
            <button class="duoNode__btn" type="button" aria-label="Food Categories" disabled>
              <span class="duoNode__icon" aria-hidden="true">🔒</span>
            </button>
          </li>

          <li class="duoNode duoNode--locked" style="--x: 1040px; --y: 85px" data-title="Serving Day" data-desc="A longer quest with mixed practice.">
            <button class="duoNode__btn" type="button" aria-label="Serving Day" disabled>
              <span class="duoNode__icon" aria-hidden="true">🔒</span>
            </button>
          </li>

          <li class="duoNode duoNode--locked" style="--x: 1180px; --y: 140px" data-title="Directions" data-desc="Follow and give simple directions inside the facility.">
            <button class="duoNode__btn" type="button" aria-label="Directions" disabled>
              <span class="duoNode__icon" aria-hidden="true">🔒</span>
            </button>
          </li>

          <li class="duoNode duoNode--locked" style="--x: 1300px; --y: 200px" data-title="Wrap-up" data-desc="Review what you learned and prep for the next unit.">
            <button class="duoNode__btn" type="button" aria-label="Wrap-up" disabled>
              <span class="duoNode__icon" aria-hidden="true">🔒</span>
            </button>
          </li>

          <li class="duoNode duoNode--locked" style="--x: 1370px; --y: 140px" data-title="Next Unit" data-desc="Keep going to unlock the next unit.">
            <button class="duoNode__btn" type="button" aria-label="Next Unit" disabled>
              <span class="duoNode__icon" aria-hidden="true">🏁</span>
            </button>
          </li>

        </ol>
      </div>
    </section>

    <aside class="panel questDetails" aria-label="Quest details">
      <div class="panel__header">
        <h2 class="panel__title">Quest</h2>
        <span class="pill" style="box-shadow:none;background:transparent">
          <span class="pill__label">Quests</span>
          <span class="pill__value" id="questProgress">0 / 10</span>
        </span>
      </div>
      <div class="panel__body">
        <div class="questDetails__kicker">
          <span aria-hidden="true">🎯</span> Recommended
        </div>
        <h3 class="questDetails__title" id="questTitle">Food Bank Tour</h3>
        <p class="questDetails__desc" id="questDesc">
          Key terms you’ll see across the Food Bank experience.
        </p>

        <div class="questDetails__ctaRow">
          <a class="btn btn--primary" href="/coursework">Start quest</a>
          <button class="btn" type="button" id="randomQuest">Pick another</button>
        </div>
      </div>
    </aside>
  </div>
</section>

<section class="chatDock" data-chat aria-label="Chat assistant">
  <div class="chatCard">
    <div class="chatHeader">
      <div class="chatTitle">
        <span aria-hidden="true">🤖</span>
        Assistant
        <span class="chatBadge">AI</span>
      </div>
      <button class="chatToggle" type="button" data-chat-toggle aria-expanded="true">
        Hide
      </button>
    </div>

    <div data-chat-panel>
      <div class="chatBody" data-chat-body></div>

      <form class="chatFooter" data-chat-form>
        <input
          class="chatInput"
          data-chat-input
          type="text"
          placeholder="Ask about quests, coursework, streaks..."
          autocomplete="off"
        />
        <button class="chatSend" data-chat-send type="submit">Send</button>
      </form>
    </div>
  </div>
</section>

<script>
  // Sync the streak number to both navbar + home pill
  const streak = window.__streakCount ?? 0;
  const el = document.getElementById("homeStreak");
  if (el) el.textContent = String(streak);

  // Simple “select quest” behavior
  const title = document.getElementById("questTitle");
  const desc = document.getElementById("questDesc");
  const nodes = Array.from(document.querySelectorAll(".duoNode"));

  function selectNode(node) {
    if (!node) return;
    const t = node.getAttribute("data-title") || "Quest";
    const d = node.getAttribute("data-desc") || "";
    if (title) title.textContent = t;
    if (desc) desc.textContent = d;
  }

  nodes.forEach((node) => {
    const btn = node.querySelector(".duoNode__btn");
    if (!btn || btn.disabled) return;
    btn.addEventListener("click", () => selectNode(node));
  });

  // Progress indicator: done quests out of total
  const progressEl = document.getElementById("questProgress");
  if (progressEl) {
    const total = nodes.length;
    const done = nodes.filter((n) => n.classList.contains("duoNode--done")).length;
    progressEl.textContent = `${done} / ${total}`;
  }

  const random = document.getElementById("randomQuest");
  if (random) {
    random.addEventListener("click", () => {
      const playable = nodes.filter((n) => !n.classList.contains("duoNode--locked"));
      const pick = playable[Math.floor(Math.random() * playable.length)];
      selectNode(pick);
    });
  }
</script>

<script src="/chat.js"></script>

