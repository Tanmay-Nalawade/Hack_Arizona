<% layout("layout") %>

<section class="cw">
  <% if (!coursework) { %>
    <p style="margin:0;color:var(--muted)">No coursework found. Run <code>npm run seed</code>.</p>
  <% } else { %>
    <div class="cw__hero">
      <h1 class="cw__title"><%= coursework.title %></h1>
      <p class="cw__desc"><%= coursework.description %></p>
      <div class="cw__meta">
        Chapters: <%= coursework.units?.length || 0 %> · Level: <%= coursework.level %>
      </div>
    </div>

    <div class="chapters" aria-label="Chapters">
      <% 
        const units = (coursework.units || []).slice().sort((a,b) => (a.order||0) - (b.order||0));
        const total = Math.max(10, units.length);
        const activeSlug = (currentUser?.courseworkProgress || []).find(p => String(p.coursework) === String(coursework._id))?.activeUnitSlug || "";
        const completed = new Set((currentUser?.courseworkProgress || []).find(p => String(p.coursework) === String(coursework._id))?.completedLessonSlugs || []);
      %>

      <% for (let i = 0; i < total; i++) { 
        const u = units[i];
        const chapterNum = i + 1;
        const slug = u?.slug || `chapter-${chapterNum}`;
        const isCurrent = activeSlug && slug === activeSlug;
        const lessonCount = u?.lessons?.length || 0;
        // crude "done" heuristic: if all lesson slugs exist in completed set
        const allLessonSlugs = (u?.lessons || []).map(l => l.slug);
        const completedCount = allLessonSlugs.filter(s => completed.has(s)).length;
        const isDone = allLessonSlugs.length > 0 && allLessonSlugs.every(s => completed.has(s));
        const isInProgress = !isDone && completedCount > 0;
        const isLocked = !u; // placeholder chapters 2..10 locked until seeded
        const cls = isDone
          ? "chapter chapter--done"
          : isCurrent
            ? "chapter chapter--current"
            : isInProgress
              ? "chapter chapter--progress"
              : isLocked
                ? "chapter chapter--locked"
                : "chapter";
        const status = isDone
          ? "Done"
          : isCurrent
            ? "Current"
            : isInProgress
              ? "In progress"
              : isLocked
                ? "Locked"
                : "Available";
      %>
        <article class="<%= cls %>">
          <div class="chapter__top">
            <div class="chapter__pill">Chapter <%= chapterNum %></div>
            <div class="chapter__status"><%= status %></div>
          </div>
          <h2 class="chapter__name"><%= u?.title || `Chapter ${chapterNum}` %></h2>
          <p class="chapter__sub">
            <%= u?.description || (isLocked ? "Unlock by completing previous chapters." : "Continue learning.") %>
          </p>
          <div class="chapter__actions">
            <span style="color:var(--muted);font-size:13px">Lessons: <%= completedCount %> / <%= lessonCount %></span>
            <a class="btn btn--primary" href="/" aria-disabled="<%= isLocked ? 'true' : 'false' %>"><%= isLocked ? "Locked" : (isCurrent ? "Continue" : "Start") %></a>
          </div>
        </article>
      <% } %>
    </div>
  <% } %>
</section>

